# Copy this file to terraform.tfvars and fill in your values.
# NEVER commit terraform.tfvars to git.

aws_region         = "us-west-2"
availability_zone  = "us-west-2a"
project_name       = "openclaw"

# Your home/office IP for SSH access (find yours at https://whatismyip.com)
allowed_ssh_cidrs = ["YOUR_IP/32"]

# Paste the contents of your public SSH key (e.g. ~/.ssh/id_ed25519.pub)
ssh_public_key = "ssh-ed25519 AAAA..."

instance_type    = "t3.medium"
root_volume_size = 30

# Native install (no Docker) -- this is the whole point of prod-v2
use_native_install = true

# Set to true if you want Tailscale installed for secure private networking
install_tailscale = false

# Set to true for AWS Systems Manager backup access
enable_ssm = false
